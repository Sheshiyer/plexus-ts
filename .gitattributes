# Normalize line endings to LF on checkout for every platform, so source-
# assertion tests that embed "\n" pass identically on Windows CI (which would
# otherwise apply core.autocrlf and check out CRLF).
* text=auto eol=lf

# Binary assets tracked via Git LFS — never normalize.
src/renderer/public/models/*.glb filter=lfs diff=lfs merge=lfs -text
*.png -text
*.jpg -text
*.jpeg -text
*.gif -text
*.ico -text
*.icns -text
*.woff -text
*.woff2 -text
*.ttf -text
