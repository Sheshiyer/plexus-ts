<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Allow JIT compilation (required for V8/Chrome) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (Electron internal) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow debugging (disable for production if not needed) -->
    <key>com.apple.security.get-task-allow</key>
    <false/>

    <!-- Microphone access for realtime audio collaboration -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Camera access for realtime video collaboration -->
    <key>com.apple.security.device.camera</key>
    <true/>
  </dict>
</plist>
